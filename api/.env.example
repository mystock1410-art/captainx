# Captain X — backend environment variables.
# Copy to .env (local) or use `fly secrets set` (production).

# Required for AI market brief (Claude Opus 4.7)
# Get key at https://console.anthropic.com/settings/keys (new accounts get $5 free credit)
ANTHROPIC_API_KEY=

# Optional — production cache (in-memory fallback works without)
# REDIS_URL=rediss://default:<token>@<host>:6379

# Optional — CORS origins (defaults to localhost:3000)
# CORS_ORIGINS=https://captainx.vercel.app
